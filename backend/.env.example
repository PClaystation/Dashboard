NODE_ENV=development
APP_NAME=continental-id-auth
PORT=5000
MONGO_URI=mongodb://localhost:27017/continental_dashboard
JWT_SECRET=replace-with-a-long-random-secret
REFRESH_TOKEN_SECRET=replace-with-a-second-long-random-secret
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# Comma-separated list of trusted frontend origins allowed by CORS.
ALLOWED_ORIGINS=https://pclaystation.github.io,https://dashboard.continental-hub.com,https://login.continental-hub.com
# Optional: allow localhost/127.0.0.1 origins outside development.
# ALLOW_LOCALHOST_ORIGINS=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=180
LOGIN_RATE_WINDOW_MS=600000
LOGIN_RATE_MAX_ATTEMPTS=8
LOGIN_BLOCK_MS=900000

# Optional HTTPS cert paths for production.
HTTPS_KEY_PATH=/etc/letsencrypt/live/mpmc.ddns.net/privkey.pem
HTTPS_CERT_PATH=/etc/letsencrypt/live/mpmc.ddns.net/fullchain.pem

# Optional Resend email configuration for account verification.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=no-reply@example.com
# EMAIL_FROM_NAME=Continental ID
# EMAIL_REPLY_TO=support@example.com
# LOGIN_POPUP_URL=https://login.continental-hub.com/popup.html
# EMAIL_VERIFY_URL=https://login.continental-hub.com/verify.html
# EMAIL_VERIFICATION_TTL_MS=86400000
