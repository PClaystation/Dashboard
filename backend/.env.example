NODE_ENV=development
APP_NAME=continental-id-auth
PORT=5000
MONGO_URI=mongodb://localhost:27017/continental_dashboard
JWT_SECRET=replace-with-a-long-random-secret
REFRESH_TOKEN_SECRET=replace-with-a-second-long-random-secret
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d
TRUST_PROXY=false

# Comma-separated list of trusted frontend origins allowed by CORS.
ALLOWED_ORIGINS=https://pclaystation.github.io,https://dashboard.continental-hub.com,https://login.continental-hub.com
# Optional: allow localhost/127.0.0.1 origins outside development.
# ALLOW_LOCALHOST_ORIGINS=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=180
LOGIN_RATE_WINDOW_MS=600000
LOGIN_RATE_MAX_ATTEMPTS=8
LOGIN_BLOCK_MS=900000
MFA_RATE_WINDOW_MS=600000
MFA_RATE_MAX_ATTEMPTS=5
MFA_BLOCK_MS=900000
PASSWORD_RESET_TTL_MS=3600000
PASSWORD_RESET_EMAIL_COOLDOWN_MS=600000
VERIFICATION_EMAIL_COOLDOWN_MS=1800000
EMAIL_DAILY_LIMIT=100
EMAIL_MONTHLY_LIMIT=3000
REFRESH_TOKEN_REPLAY_GRACE_MS=15000

# Optional HTTPS cert paths for production.
HTTPS_KEY_PATH=/etc/letsencrypt/live/mpmc.ddns.net/privkey.pem
HTTPS_CERT_PATH=/etc/letsencrypt/live/mpmc.ddns.net/fullchain.pem

# Optional Resend email configuration for account verification.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=no-reply@example.com
# EMAIL_FROM_NAME=Continental ID
# EMAIL_REPLY_TO=support@example.com
# LOGIN_POPUP_URL=https://login.continental-hub.com/popup.html
# EMAIL_VERIFY_URL=https://login.continental-hub.com/verify.html
# EMAIL_VERIFICATION_TTL_MS=86400000
# EMAIL_HERO_IMAGE_URL=https://dashboard.continental-hub.com/email-hero.png

# Optional WebAuthn/passkey configuration.
# WEBAUTHN_RP_NAME=Continental ID
# WEBAUTHN_RP_ID=continental-hub.com

# Optional OAuth provider configuration.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_OAUTH_CALLBACK_URL=https://auth.example.com/api/auth/oauth/github/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_CALLBACK_URL=https://auth.example.com/api/auth/oauth/google/callback
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_OAUTH_CALLBACK_URL=https://auth.example.com/api/auth/oauth/discord/callback
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common
# MICROSOFT_OAUTH_CALLBACK_URL=https://auth.example.com/api/auth/oauth/microsoft/callback
