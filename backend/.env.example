NODE_ENV=development
APP_NAME=continental-id-auth
PORT=5000
MONGO_URI=mongodb://localhost:27017/continental_dashboard
JWT_SECRET=replace-with-a-long-random-secret
REFRESH_TOKEN_SECRET=replace-with-a-second-long-random-secret
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# Comma-separated list of explicit non-localhost origins allowed by CORS.
ALLOWED_ORIGINS=https://pclaystation.github.io,https://dashboard.continental-hub.com,https://login.continental-hub.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=180
LOGIN_RATE_WINDOW_MS=600000
LOGIN_RATE_MAX_ATTEMPTS=8
LOGIN_BLOCK_MS=900000

# Optional HTTPS cert paths for production.
HTTPS_KEY_PATH=/etc/letsencrypt/live/mpmc.ddns.net/privkey.pem
HTTPS_CERT_PATH=/etc/letsencrypt/live/mpmc.ddns.net/fullchain.pem

# Optional email configuration.
# Option A: SMTP
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
# EMAIL_SECURE=true
# EMAIL_USER=your-user
# EMAIL_PASS=your-pass
# EMAIL_FROM=no-reply@example.com

# Option B: Named email service
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-user
# EMAIL_PASS=your-pass
# EMAIL_FROM=no-reply@example.com
